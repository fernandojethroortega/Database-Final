NODE_ENV=production
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-secret

# PostgreSQL connection from Supabase, Neon, Railway, or Render PostgreSQL
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require

# First admin account
ADMIN_EMAIL=admin@pis.edu.ph
ADMIN_PASSWORD=ChangeMeAdmin123!
ADMIN_NAME=System Administrator

# Cloudinary profile picture storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pis-fms-profile-pictures
